{
  "name": "nerdy-frontend",
  "private": true,
  "packageManager": "pnpm@8.14.0",
  "scripts": {
    "dev": "NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-dev} next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "next typegen && tsc -p tsconfig.typecheck.json --noEmit",
    "verify": "pnpm test && pnpm build && pnpm typecheck",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@react-three/drei": "^9.119.1",
    "@react-three/fiber": "^8.18.0",
    "firebase": "^12.10.0",
    "next": "15",
    "react": "19",
    "react-dom": "19",
    "three": "^0.174.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
